# ==============================================================
# ENVIRONMENT VARIABLES — Copy this file to .env for local dev
# ==============================================================

# Gemini AI API Key
# - Local dev: add to your .env file
# - Vercel: add in Project Settings → Environment Variables
# IMPORTANT: Must be prefixed with VITE_ to be exposed to the browser bundle
VITE_GEMINI_API_KEY="your_gemini_api_key_here"
